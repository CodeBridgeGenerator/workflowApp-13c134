{
  "_id": {
    "$oid": "694a1dda94f2f8e0f79174f6"
  },
  "serviceName": "userAddresses",
  "content": "<p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">User Addresses</strong></p><p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Overview:</strong></p><p><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">User Addresses module maintains the list of addresses associated with users. It allows Admins to add, view, and manage user address details efficiently.</span></p><p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Steps to Manage User Addresses:</strong></p><ol><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Admin</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> can navigate to </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">User Addresses</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> from the menu.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Click the </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Add</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> button to create a new address record.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Enter the address details, including </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Street 1, Street 2, Postcode, City, State, Province and Country.</strong></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Existing address records can be viewed, edited, or deleted as needed.</span></li></ol>",
  "createdBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
  "updatedBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
