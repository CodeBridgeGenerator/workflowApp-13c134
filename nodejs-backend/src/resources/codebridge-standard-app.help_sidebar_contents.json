  "_id": {
    "$oid": "694a1d8994f2f8e0f7916cb9"
  },
  "serviceName": "users",
  "content": "<p><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Users</strong></p><p><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Overview:</strong></p><p><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">Users module maintains the list of all users who are using the system. It allows Admins to view, manage, and access detailed information for each user, including their profiles, contact details, and addresses.</span></p><p><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Steps to Manage Users:</strong></p><ol><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Admin</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> can navigate to </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Users</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> from the menu.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">The table displays </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">user names</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> and </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">email addresses</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">Admins can </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">edit</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> or </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">delete</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> users directly from the table.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">Click on any user record to open the </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Single User Page</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">, which displays Full user details, Associated </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">profiles, Phone number and Address.</strong></li></ol>",
  "createdBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
