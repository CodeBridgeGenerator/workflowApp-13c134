{
  "_id": {
    "$oid": "694a1e4a94f2f8e0f7918064"
  },
  "serviceName": "userInvites",
  "content": "<p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">User Invites</strong></p><p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Overview:</strong></p><p><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">User Invites module allows Admins to manage invitation emails, verification codes, and email counters. It helps control signup attempts and ensures that users can retry email verification if the limit is reached.</span></p><p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Steps to Manage User Invites:</strong></p><ol><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Admin</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> can navigate to </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">User Invites</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> from the menu.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">The module displays </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Invitation Email, Verification Code and Mail Counter.</strong></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">If the </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Mail Counter</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> reaches 3, the user cannot attempt email verification for signup.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Admins can </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">reset or reduce the mail counter</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> to allow the user to try signup and verification again.</span></li></ol>",
  "createdBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
  "updatedBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
  "createdAt": {
    "$date": "2025-12-23T04:44:58.273Z"
  },
  "updatedAt": {
    "$date": "2025-12-23T04:44:58.273Z"
  },
  "__v": 0
