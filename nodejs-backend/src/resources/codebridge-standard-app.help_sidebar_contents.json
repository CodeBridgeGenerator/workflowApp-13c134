{
  "_id": {
    "$oid": "694a1ecf94f2f8e0f7918dcd"
  },
  "serviceName": "profiles",
  "content": "<p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Profiles</strong></p><p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Overview:</strong></p><p><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Profiles maintain the list of user profiles in the system. A single user can have </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">multiple profiles</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">. Profiles store detailed information about users, including their role, position, and contact details.</span></p><p><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Steps to Manage Profiles:</strong></p><ol><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Admin</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> can navigate to </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Profiles</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> from the menu.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Click the </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Add</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> button to create a new profile and enter details such as </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Name, Bio, Company, Branch, Phone Number, Address, User</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> (associated user), </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">Role and Position.</strong></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Existing profiles can be </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">edited</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> or </span><strong style=\"background-color: transparent; color: rgb(0, 0, 0);\">deleted</strong><span style=\"background-color: transparent; color: rgb(0, 0, 0);\"> as needed.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"background-color: transparent; color: rgb(0, 0, 0);\">Profiles allow the system to manage multiple roles and positions per user and provide detailed user information for administrative purposes.</span></li></ol>",
  "createdBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
  "updatedBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
