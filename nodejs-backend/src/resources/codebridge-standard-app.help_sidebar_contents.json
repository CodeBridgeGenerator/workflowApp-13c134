{
  "_id": {
    "$oid": "694a1df394f2f8e0f7917789"
  },
  "serviceName": "userPhones",
  "content": "<p><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">User Phones</strong></p><p><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Overview:</strong></p><p><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">User Phones module maintains the phone numbers associated with users. It allows Admins to add, view, and manage user contact numbers, specifying the type and dialing details for each.</span></p><p><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Steps to Manage User Phones:</strong></p><ol><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Admin</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> can navigate to </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">User Phones</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> from the menu.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">Click the </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Add</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> button to create a new phone record.</span></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">Enter the phone details, including </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">User, Country, Phone Number, Type</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> (Landline, Mobile, Fax, WA Only, SMS Only) and </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">Dialing Number.</strong></li><li data-list=\"ordered\"><span class=\"ql-ui\" contenteditable=\"false\"></span><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">Existing phone records can be </span><strong style=\"color: rgb(0, 0, 0); background-color: transparent;\">viewed, edited, or deleted</strong><span style=\"color: rgb(0, 0, 0); background-color: transparent;\"> as needed.</span></li></ol>",
  "createdBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
  "updatedBy": {
    "$oid": "681d8d2bf3a2818d4b95c5c3"
  },
